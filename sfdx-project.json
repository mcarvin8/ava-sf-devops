{
  "packageDirectories": [
    {
      "path": "force-app",
      "default": true
    }
  ],
  "namespace": "",
  "sfdcLoginUrl": "https://login.salesforce.com",
  "plugins": {
    "dependencies": [
      { "namespace": "blng" },
      { "namespace": "CameleonCPQ" },
      { "namespace": "ChargentBase" },
      { "namespace": "ChargentOrders" },
      { "namespace": "ChrgntBllng" },
      { "namespace": "ContinuousCB" },
      { "namespace": "ContinuousSFBU" },
      { "namespace": "dfscpq" },
      { "namespace": "dfsle" },
      { "namespace": "dsfs" },
      { "namespace": "fferpcore" },
      { "namespace": "Gong" },
      { "namespace": "n2de" },
      { "namespace": "pse" },
      { "namespace": "rh2" },
      { "namespace": "sbaa" },
      { "namespace": "SBQQ" },
      { "namespace": "SFBD" },
      { "namespace": "WorkRampApp" }
    ]
  },
  "replacements": [
    {
      "glob": "force-app/main/default/bots/**/*.bot-meta.xml",
      "regexToReplace": "<botUser>.*?</botUser>",
      "replaceWithFile": "scripts/replacementFiles/devBotUser.txt",
      "replaceWhenEnv": [{
        "env": "AUTH_ALIAS",
        "value": "SANDBOX"
      }] 
    },
    {
      "glob": "force-app/main/default/bots/**/*.bot-meta.xml",
      "regexToReplace": "<botUser>.*?</botUser>",
      "replaceWithFile": "scripts/replacementFiles/fqaBotUser.txt",
      "replaceWhenEnv": [{
        "env": "AUTH_ALIAS",
        "value": "FQA"
      }] 
    },
    {
      "glob": "force-app/main/default/bots/**/*.bot-meta.xml",
      "regexToReplace": "<botUser>.*?</botUser>",
      "replaceWithFile": "scripts/replacementFiles/prdBotUser.txt",
      "replaceWhenEnv": [{
        "env": "AUTH_ALIAS",
        "value": "PRD"
      }] 
    }
  ]
}
